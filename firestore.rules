rules_version = '2';

// =============================================================================
//  REGUŁY BEZPIECZEŃSTWA FIRESTORE
//  Wklej całość w konsoli Firebase: Firestore Database → zakładka "Rules" →
//  "Publish". Bez tego baza będzie albo otwarta na oścież, albo zablokowana.
//
//  WAŻNE: zmień adres admina poniżej, jeśli to nie Ty masz wpisywać wyniki.
// =============================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && request.auth.token.email == "mateuszjoe@gmail.com";
    }

    // Typy graczy: PUBLICZNY odczyt (ranking widoczny też dla niezalogowanych,
    // jako zachęta "ktoś już gra"). Pisać wolno tylko we własnym dokumencie;
    // USUWAĆ może właściciel albo admin (wykopywanie niechcianych graczy).
    // Uwaga: publiczny odczyt = nicki/avatary/punkty ORAZ pole email są widoczne
    // dla każdego z linkiem.
    match /predictions/{uid} {
      allow read: if true;
      allow create, update: if isSignedIn() && request.auth.uid == uid;
      allow delete: if isAdmin() || (isSignedIn() && request.auth.uid == uid);
    }

    // Wyniki meczów i zwycięzca turnieju: PUBLICZNY odczyt (ranking liczy się
    // też dla niezalogowanych), pisze wyłącznie admin.
    match /admin/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Czat: czyta każdy; pisać może zalogowany TYLKO we własnym imieniu (uid),
    // bez edycji; usuwać może autor lub admin.
    match /chat/{msgId} {
      allow read: if true;
      allow create: if isSignedIn()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.text is string
        && request.resource.data.text.size() <= 1000;
      allow update: if false;
      allow delete: if isAdmin() || (isSignedIn() && resource.data.uid == request.auth.uid);
    }

    // Subskrypcje push: gracz zapisuje tylko własną; czyta je wyłącznie robot
    // (konto serwisowe pomija reguły), więc klientom czytania zabraniamy.
    match /pushSubs/{uid} {
      allow read: if false;
      allow write: if isSignedIn() && request.auth.uid == uid;
    }

    // Stan wysyłki powiadomień — tylko serwer (konto serwisowe).
    match /push/{docId} {
      allow read, write: if false;
    }
  }
}
